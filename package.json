{
  "name": "stemdeck",
  "version": "0.1.0",
  "description": "Open-source desktop DJ app with AI stem separation, keylock pitch/tempo control, and beat sync — powered by your local music files.",
  "main": "./out/main/index.js",
  "license": "MIT",
  "author": "Alexander Liteplo",
  "repository": {
    "type": "git",
    "url": "https://github.com/AlexanderLiteplo/stemdeck.git"
  },
  "scripts": {
    "build:worklet": "esbuild src/worklet/deck-processor.ts --bundle --format=iife --outfile=src/renderer/public/worklets/deck-processor.js",
    "dev": "npm run build:worklet && electron-vite dev",
    "build": "npm run build:worklet && electron-vite build",
    "start": "npm run build && electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "soundtouchjs": "^0.3.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^41.7.1",
    "electron-vite": "^5.0.0",
    "esbuild": "^0.28.1",
    "typescript": "^6.0.3",
    "vite": "^7.3.6"
  }
}
